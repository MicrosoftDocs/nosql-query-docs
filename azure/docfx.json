          "**/*.yml"
        ],
        "exclude": [
          "**/obj/**",
          "**/includes/**",
          "_themes/**",
          "**/docfx.json",
          "_repo.en-us/**",
          "README.md",
          "LICENSE",
          "LICENSE-CODE",
          "ThirdPartyNotices.md",
          "SECURITY.md"
        ]
      },
      {
        "files": [
          "zone-pivot-groups.yml"
        ],
        "src": "zone-pivots",
        "dest": "zone-pivots/azure-nosql/"
      }
    ],
    "resource": [
      {
        "files": [
          "**/*.gif",
